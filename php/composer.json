{
    "name": "approute/public-api-sdk",
    "description": "Official PHP SDK for AppRoute Public API",
    "type": "library",
    "license": "MIT",
    "version": "1.0.0",
    "require": {
        "php": ">=8.1",
        "guzzlehttp/guzzle": "^7.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "AppRoute\\Sdk\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AppRoute\\Sdk\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
